DATA_PATH=../nui_ba_den_tourism_database.xlsx
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=nui_ba_den_rag
AUTO_BUILD_CHROMA_ON_STARTUP=false

# Supabase Postgres. Dung connection string pooler, vi du:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?ssl=require
DATABASE_URL=

# OpenAI-compatible router, vi du 9router/OpenRouter/local gateway.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.9router.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_TOKENS=900
OPENAI_TEMPERATURE=0.2

EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
EMBEDDING_ALLOW_DOWNLOAD=false
RAG_TOP_K=6

CORS_ORIGINS=*
LOG_LEVEL=INFO
